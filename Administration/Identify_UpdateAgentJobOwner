USE msdb;
GO
SELECT j.job_id, p.name, j.name
FROM dbo.sysjobs AS j
INNER JOIN dbo.sysjobsteps AS s 
    ON j.job_id = s.job_id
LEFT OUTER JOIN sys.server_principals AS p 
    ON j.owner_sid = p.sid
WHERE p.[name] IS NULL
UNION
SELECT j.job_id, p.name, j.name
FROM dbo.sysjobs AS j
INNER JOIN dbo.sysjobsteps AS s 
    ON j.job_id = s.job_id
LEFT OUTER JOIN sys.server_principals AS p 
    ON j.owner_sid = p.sid
	WHERE p.[name] IS NOT NULL
	ORDER BY p.name, j.name

-- 1. Declare variables to store the job ID and the new owner login name
DECLARE @JobId UNIQUEIDENTIFIER;
DECLARE @NewOwner SYSNAME = 'sa'; -- <-- REPLACE THIS with your desired login name

-- 2. Define the cursor based on your original filtering logic
DECLARE JobOwnerCursor CURSOR FOR
SELECT j.job_id
FROM dbo.sysjobs AS j
INNER JOIN dbo.sysjobsteps AS s 
    ON j.job_id = s.job_id
LEFT OUTER JOIN sys.server_principals AS p 
    ON j.owner_sid = p.sid
WHERE p.[name] IS NULL;

-- 3. Open the cursor and begin looping
OPEN JobOwnerCursor;

FETCH NEXT FROM JobOwnerCursor INTO @JobId;

WHILE @@FETCH_STATUS = 0
BEGIN
    -- 4. Update the job owner using the system stored procedure
    EXEC dbo.sp_update_job 
        @job_id = @JobId, 
        @owner_login_name = @NewOwner;

    FETCH NEXT FROM JobOwnerCursor INTO @JobId;
END;

-- 5. Clean up the cursor resources
CLOSE JobOwnerCursor;
DEALLOCATE JobOwnerCursor;
GO
